{
  "name": "kkc-adventure",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node src/index.ts\"",
    "web": "nodemon --watch src --ext ts --exec \"ts-node src/server.ts\"",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "cli": "node dist/index.js",
    "db:seed": "ts-node -r dotenv/config src/db/seed.ts",
    "test": "jest"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ]
  }
}
